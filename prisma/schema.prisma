// Filtre Maroc — database schema (Supabase Postgres via Prisma)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  categorySlug     String
  shortDescription String   @default("")
  description      String   @default("")
  price            Int
  oldPrice         Int?
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  stages           Int?
  capacity         String?
  warranty         String?
  badges           String[] @default([])
  inStock          Boolean  @default(true)
  stock            Int      @default(0)
  bestSeller       Boolean  @default(false)
  hue              Int      @default(205)
  images           String[] @default([])
  features         String[] @default([])
  specs            Json     @default("[]")
  variants         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([categorySlug])
}

model Order {
  id               String    @id
  customerName     String
  phone            String
  city             String
  address          String
  note             String?
  items            Json      @default("[]")
  total            Int
  status           String    @default("pending")
  confirmationNote String?
  source           String    @default("web") // "web" | "phone"
  confirmedAt      DateTime?
  installDate      DateTime? // scheduled installation date/time
  assignedTo       String? // plombier email the job is assigned to
  completedAt      DateTime? // when the plombier marked it installed
  photoUrl         String? // completion photo uploaded by the plombier
  installStage     String? // plombier progress: "enroute" | "arrived" (null = scheduled)
  kind             String    @default("install") // "install" | "maintenance"
  parentOrderId    String? // for a maintenance visit: the original installation
  warrantyMonths   Int       @default(24) // warranty length from completion
  maintenanceMonths Int      @default(6) // months between maintenance visits
  nextMaintenanceAt DateTime? // when the next filter change is due
  lastMaintenanceAt DateTime? // last maintenance done
  createdAt        DateTime  @default(now())

  @@index([status])
  @@index([assignedTo])
  @@index([kind])
  @@index([nextMaintenanceAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("admin") // "admin" | "confirmateur" | "plombier"
  city         String? // plombier coverage city/zone (for dispatch)
  createdAt    DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
}

model SiteSettings {
  id                     String   @id @default("main")
  siteName               String   @default("Filtre Maroc")
  logoUrl                String?
  phone1                 String   @default("")
  phone2                 String?
  email                  String?
  whatsapp               String?
  addressText            String?
  mapLat                 Float?
  mapLng                 Float?
  facebook               String?
  instagram              String?
  tiktok                 String?
  announcement           String?
  freeDeliveryThreshold  Int      @default(1000)
  updatedAt              DateTime @updatedAt
}
