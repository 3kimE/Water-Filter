# Copy this file to `.env` and fill every value. Do NOT commit `.env`.
# (Real values are kept out of git; see DEPLOYMENT-KEYS.local.md for the live ones.)

# --- Supabase Postgres (Prisma) ---
# Pooled connection (app runtime). connection_limit gives headroom for parallel queries.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=10"
# Direct connection (migrations / prisma db push).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Admin session signing secret (REQUIRED, must be >= 32 random chars) ---
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# --- Supabase API (product + completion-photo storage) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Order/email alerts (Resend) — without these, emails simply won't send ---
RESEND_API_KEY=""
ORDER_NOTIFY_EMAIL="owner@example.com"
# Use a verified domain sender in production (the resend.dev sandbox only delivers to verified addresses).
ORDER_FROM_EMAIL="Filtre Maroc <noreply@yourdomain.com>"

# --- Base URL used in transactional email links (REQUIRED in production) ---
# If unset, email links fall back to http://localhost:3000.
APP_URL="https://yourdomain.com"
